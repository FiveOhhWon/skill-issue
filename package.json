{
  "name": "skill-issue",
  "version": "1.0.0",
  "private": true,
  "description": "Newsletter operations plugin for agentskills.io",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "build:shared": "npm run build -w packages/shared",
    "build:slack-bot": "npm run build -w apps/slack-bot",
    "build:skillkit": "npm run build -w apps/skillkit",
    "build:web": "npm run build -w apps/web",
    "dev:web": "npm run dev -w apps/web",
    "start:slack-bot": "npm run build:slack-bot && npm run start -w apps/slack-bot",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
